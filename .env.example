# AWDP Scanner 配置模板
# 用法:
# 1. 复制本文件为 .env
# 2. awdp_pro_scanner.py / build_vector_db.py 会自动读取仓库根目录 .env
# 3. 已存在的系统环境变量优先级更高，不会被 .env 覆盖

# --- Ollama / 主模型 ---
# OLLAMA_BASE_URL
# 作用: 本地 Ollama 服务地址
# 默认: http://localhost:11434
# 推荐: 保持本机默认地址
# 影响: 地址错误会导致扫描前健康检查失败
OLLAMA_BASE_URL=http://localhost:11434

# AWDP_MODEL_NAME
# 作用: 漏洞判定与修复建议使用的本地模型
# 默认: qwen2.5-coder:14b
# 推荐: 与本地实际 `ollama pull` 的模型保持一致
# 影响: 模型越大通常效果更稳，但速度和显存占用更高
AWDP_MODEL_NAME=qwen2.5-coder:14b

# --- 本地 embedding / RAG ---
# AWDP_EMBED_MODEL_NAME
# 作用: 本地 embedding 模型目录名
# 默认: all-MiniLM-L6-v2
# 推荐: 与 models/ 下实际目录一致
# 影响: 与现有向量库元数据不一致时，扫描阶段会自动禁用 RAG
AWDP_EMBED_MODEL_NAME=all-MiniLM-L6-v2

# AWDP_EMBED_MODEL_PATH
# 作用: 自定义本地 embedding 模型路径
# 默认: ./models/<AWDP_EMBED_MODEL_NAME>
# 推荐: 使用默认目录结构时留空
# 影响: 路径错误会导致建库失败或扫描时禁用 RAG
# AWDP_EMBED_MODEL_PATH=./models/all-MiniLM-L6-v2

# AWDP_RAG_MODE
# 作用: 控制知识库在扫描中的参与方式
# 默认: repair_only
# 推荐: repair_only
# 影响:
# - off: 更快，但没有知识库修复约束
# - prejudge: 判定前也会参考知识库，噪声更高，偏实验性
# - repair_only: 仅在修复阶段参考知识库，最稳妥
AWDP_RAG_MODE=repair_only

# AWDP_RAG_TOP_K
# 作用: 每次检索最多取多少条知识库片段
# 默认: 2
# 推荐: 2~3
# 影响: 过大更容易引入无关修复约束
AWDP_RAG_TOP_K=2

# AWDP_RAG_SCORE_THRESHOLD
# 作用: 检索分数阈值，越小越严格
# 默认: 1.2
# 推荐: 0.8~1.2
# 影响: 过小可能漏掉知识片段，过大可能引入噪声
AWDP_RAG_SCORE_THRESHOLD=1.2

# --- 扫描行为 ---
# AWDP_SCAN_UPLOADS
# 作用: 是否扫描常见 uploads 目录
# 默认: true
# 推荐: true
# 影响: false 会更快，但会漏掉上传落地脚本、webshell、危险附件处理逻辑
AWDP_SCAN_UPLOADS=true

# AWDP_EXTRA_IGNORE_DIRS
# 作用: 额外忽略目录，多个目录用逗号分隔
# 默认: 空
# 推荐: 仅在明确确认目录无源码价值时再配置
# 影响: 写错会直接少扫目录
AWDP_EXTRA_IGNORE_DIRS=

# AWDP_MAX_WORKERS
# 作用: 并发扫描线程数
# 默认: 1
# 推荐: 1~2
# 影响: 增大可提速，但会加重本地 Ollama 并发压力并提高抖动
AWDP_MAX_WORKERS=1

# AWDP_MIN_VULN_CONFIDENCE
# 作用: 报告中的最小参考置信度参数
# 默认: 0.7
# 推荐: 0.65~0.8
# 影响: 越低越倾向保守留给人工复核，越高可能压掉边界问题
AWDP_MIN_VULN_CONFIDENCE=0.7

# --- Ollama 请求参数 ---
# AWDP_OLLAMA_TIMEOUT
# 作用: 单次 Ollama 请求超时秒数
# 默认: 180
# 推荐: 180~300
# 影响: 机器较慢时可适当增大，否则会误报模型超时
AWDP_OLLAMA_TIMEOUT=180

# AWDP_OLLAMA_NUM_PREDICT
# 作用: 通用生成上限
# 默认: 768
# 推荐: 512~1024
# 影响: 越大通常修复建议更完整，但响应更慢
AWDP_OLLAMA_NUM_PREDICT=768

# AWDP_DETECTION_NUM_PREDICT
# 作用: 漏洞判定阶段的生成上限
# 默认: min(512, AWDP_OLLAMA_NUM_PREDICT)
# 推荐: 256~512
# 影响: 太小可能导致 JSON 不完整，太大则徒增延迟
AWDP_DETECTION_NUM_PREDICT=512

# AWDP_REPAIR_NUM_PREDICT
# 作用: 修复建议阶段的生成上限
# 默认: AWDP_OLLAMA_NUM_PREDICT
# 推荐: 512~1024
# 影响: 太小可能导致修复片段不完整
AWDP_REPAIR_NUM_PREDICT=768

# AWDP_MODEL_RETRIES
# 作用: 模型调用失败时的重试次数
# 默认: 2
# 推荐: 2~3
# 影响: 增大可降低偶发失败，但总耗时会更长
AWDP_MODEL_RETRIES=2

# --- 大文件 / 片段控制 ---
# AWDP_FULL_FILE_MODEL_CHAR_LIMIT
# 作用: 允许整文件直接送模型的字符上限
# 默认: 6000
# 推荐: 4000~8000
# 影响: 越大上下文更多，但更慢、更容易挤压输出空间
AWDP_FULL_FILE_MODEL_CHAR_LIMIT=6000

# AWDP_MAX_MODEL_INPUT_CHARS
# 作用: 送入模型的最大字符数
# 默认: 9000
# 推荐: 7000~10000
# 影响: 越大越慢，且更容易让修复建议被截断
AWDP_MAX_MODEL_INPUT_CHARS=9000

# AWDP_SNIPPET_CONTEXT_LINES
# 作用: 片段模式下每个命中点保留的上下文行数
# 默认: 12
# 推荐: 8~16
# 影响: 越大越容易保留业务上下文，但也会增加噪声
AWDP_SNIPPET_CONTEXT_LINES=12

# --- 向量库构建 ---
# AWDP_REBUILD_DB
# 作用: 是否强制全量重建 chroma_db
# 默认: false
# 推荐: 仅在知识库或 embedding 模型明显变更后设为 true
# 影响: true 会备份旧库并全量重建，耗时更长
AWDP_REBUILD_DB=false

# AWDP_RAG_CHUNK_SIZE
# 作用: Markdown 切分片段大小
# 默认: 2500
# 推荐: 1800~3000
# 影响: 越大单片上下文更完整，但检索粒度更粗
AWDP_RAG_CHUNK_SIZE=2500

# AWDP_RAG_CHUNK_OVERLAP
# 作用: 片段重叠字符数
# 默认: 200
# 推荐: 100~300
# 影响: 越大召回更稳，但建库更慢、向量库更大
AWDP_RAG_CHUNK_OVERLAP=200

# AWDP_KNOWLEDGE_GLOB
# 作用: 知识库 Markdown 匹配规则
# 默认: **/*.md
# 推荐: 默认
# 影响: 配错会直接导致建库读不到文档
AWDP_KNOWLEDGE_GLOB=**/*.md
